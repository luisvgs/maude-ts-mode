{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "maude",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_token"
      }
    },
    "_token": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "keyword"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "other"
        },
        {
          "type": "SYMBOL",
          "name": "base_type"
        }
      ]
    },
    "keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "fmod"
        },
        {
          "type": "STRING",
          "value": "endfm"
        },
        {
          "type": "STRING",
          "value": "mod"
        },
        {
          "type": "STRING",
          "value": "endm"
        },
        {
          "type": "STRING",
          "value": "op"
        },
        {
          "type": "STRING",
          "value": "sort"
        },
        {
          "type": "STRING",
          "value": "eq"
        },
        {
          "type": "STRING",
          "value": "rl"
        },
        {
          "type": "STRING",
          "value": "is"
        }
      ]
    },
    "base_type": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "Nat"
        },
        {
          "type": "STRING",
          "value": "Bool"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "other": {
      "type": "PATTERN",
      "value": "[^\\s]+"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}