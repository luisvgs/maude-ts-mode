{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "maude",
      "camelcase": "Maude",
      "title": "Maude",
      "scope": "source.maude",
      "file-types": [
        "maude"
      ],
      "injection-regex": "^maude$",
      "class-name": "TreeSitterMaude"
    }
